RunService.Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart

    -- Авто-подбор пистолета
    if Settings.AutoGetGun then
        local gunDrop = Workspace:FindFirstChild("GunDrop")
        if gunDrop and gunDrop:IsA("Model") then
            local part = gunDrop:FindFirstChild("Part") or gunDrop:FindFirstChildWhichIsA("BasePart")
            if part then
                hrp.CFrame = part.CFrame * CFrame.new(0, 0, 0)
            end
        end
    end

-- Добавленный вами блок авто-сбора монет
if Settings.CoinFarm then
    local container = Workspace:FindFirstChild("Normal") or Workspace:FindFirstChild("Innocent")

    if container and container:FindFirstChild("CoinContainer") then
        for _, coin in pairs(container.CoinContainer:GetChildren()) do
            if coin:IsA("BasePart") or coin:FindFirstChildWhichIsA("BasePart") then
                local coinPart = coin:IsA("BasePart")
                    and coin
                    or coin:FindFirstChildWhichIsA("BasePart")

                if (coinPart.Position - hrp.Position).Magnitude < 250 then
                    coinPart.CFrame = hrp.CFrame
                end
            end
        end
    end
end


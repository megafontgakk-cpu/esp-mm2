local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- Настройка цветов подсветки
local COLORS = {
    Murderer = Color3.fromRGB(255, 0, 0), -- Красный для Убийцы
    Sheriff = Color3.fromRGB(0, 0, 255),  -- Синий для Шерифа
    Innocent = Color3.fromRGB(0, 255, 0)  -- Зеленый для Мирных
}

-- Функция определения роли игрока по оружию
local function getPlayerRole(player)
    if not player then return "Innocent" end
    
    local backpack = player:FindFirstChild("Backpack")
    local character = player.Character
    
    local function hasItem(name)
        return (backpack and backpack:FindFirstChild(name)) or (character and character:FindFirstChild(name))
    end
    
    if hasItem("Knife") then
        return "Murderer"
    elseif hasItem("Gun") then
        return "Sheriff"
    end
    
    return "Innocent"
end

-- Функция создания подсветки сквозь стены
local function createHighlight(player)
    if player == LocalPlayer then return end
    
    RunService.RenderStepped:Connect(function()
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local highlight = char:FindFirstChild("RoleHighlight")
            if not highlight then
                highlight = Instance.new("Highlight")
                highlight.Name = "RoleHighlight"
                highlight.Parent = char
                highlight.FillOpacity = 0.25
                highlight.OutlineOpacity = 1
            end
            
            local role = getPlayerRole(player)
            highlight.FillColor = COLORS[role]
            highlight.OutlineColor = COLORS[role]
        end
    end)
end

-- Функция телепортации к выпавшему пистолету
local function teleportToGun()
    local gunDrop = Workspace:FindFirstChild("GunDrop")
    
    if gunDrop and gunDrop:IsA("Model") then
        local part = gunDrop:FindFirstChild("Part") or gunDrop:FindFirstChildWhichIsA("BasePart")
        local character = LocalPlayer.Character
        
        if part and character and character:FindFirstChild("HumanoidRootPart") then
            -- Телепортируем чуть выше пистолета, чтобы персонаж коснулся его и подобрал
            character.HumanoidRootPart.CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0))
        end
    end
end

-- Отслеживание нажатия клавиши "E"
UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    -- gameProcessedEvent нужен, чтобы телепорт не срабатывал, когда вы пишете в чат
    if not gameProcessedEvent and input.KeyCode == Enum.KeyCode.E then
        teleportToGun()
    end
end)

-- Инициализация ESP для текущих игроков
for _, player in pairs(Players:GetPlayers()) do
    createHighlight(player)
end

-- Инициализация ESP для новых игроков
Players.PlayerAdded:Connect(createHighlight)

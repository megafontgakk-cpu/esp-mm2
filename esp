-- 1. БЕЗОПАСНЫЙ ТЕЛЕПОРТ К ПИСТОЛЕТУ ЧЕРЕЗ TWEEN (Летит сквозь стены на высокой скорости)
local function teleportToGun()
    local gunDrop = Workspace:FindFirstChild("GunDrop")
    if gunDrop then
        local part = gunDrop:FindFirstChild("Part") or gunDrop:FindFirstChildWhichIsA("BasePart")
        local character = LocalPlayer.Character
        if part and character and character:FindFirstChild("HumanoidRootPart") then
            local hrp = character.HumanoidRootPart
            
            -- Рассчитываем время полета до пистолета на основе расстояния
            local distance = (part.Position - hrp.Position).Magnitude
            local duration = distance / 150 -- Безопасная скорость левитации
            
            local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
            local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0))})
            
            -- Временно включаем Ноуклип во время полета к пистолету
            local tempNoclip = RunService.Stepped:Connect(function()
                for _, p in pairs(character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end)
            
            tween:Play()
            tween.Completed:Connect(function()
                tempNoclip:Disconnect()
                hrp.AssemblyLinearVelocity = Vector3.zero
            end)
        end
    end
end

-- 2. СТАБИЛЬНЫЙ ПОЛЕТ (БЕЗ VELOCITY — ОБХОД ЗАВИСАНИЯ)
RunService.RenderStepped:Connect(function()
    if isFlying and Settings.Fly and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local camera = Workspace.CurrentCamera
        local moveDir = Vector3.new(0,0,0)
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
        
        if moveDir.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (moveDir.Unit * (Settings.FlySpeed / 60))
        end
        hrp.AssemblyLinearVelocity = Vector3.zero -- Отключаем гравитацию, убирает лаги падения
    end
end)

-- Отслеживание горячих клавиш X, P, E
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    -- Полет на кнопку X
    if input.KeyCode == Enum.KeyCode.X and Settings.Fly then
        local char = LocalPlayer.Character
        if char then
            isFlying = not isFlying
            -- Переключаем состояние физики, обходя Byfron
            char:FindFirstChildOfClass("Humanoid").PlatformStand = isFlying
            if not isFlying then hrp.AssemblyLinearVelocity = Vector3.zero end
        end
    end
    
    -- Телепорт на кнопку E
    if input.KeyCode == Enum.KeyCode.E and Settings.TPOnE then
        teleportToGun()
    end
    
    -- Ноуклип на кнопку P
    if input.KeyCode == Enum.KeyCode.P then
        Settings.Noclip = not Settings.Noclip
    end
end)

-- 3. ESP Подсветка
local function getPlayerRole(player)
    if not player then return "Innocent" end
    local bp = player:FindFirstChild("Backpack")
    local char = player.Character
    if (bp and bp:FindFirstChild("Knife")) or (char and char:FindFirstChild("Knife")) then return "Murderer" end
    if (bp and bp:FindFirstChild("Gun")) or (char and char:FindFirstChild("Gun")) then return "Sheriff" end
    return "Innocent"
end

RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local highlight = player.Character:FindFirstChild("RoleHighlight")
            if Settings.ESP then
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "RoleHighlight"
                    highlight.Parent = player.Character
                    highlight.FillOpacity = 0.3
                    highlight.OutlineOpacity = 1
                end
                local role = getPlayerRole(player)
                highlight.FillColor = COLORS[role]
                highlight.OutlineColor = COLORS[role]
            else
                if highlight then highlight:Destroy() end
            end
        end
    end
end)


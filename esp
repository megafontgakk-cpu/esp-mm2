local buttonCount = 0
local function createToggle(text, configKey, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 220, 0, 32)
    btn.Position = UDim2.new(0, 15, 0, 15 + (buttonCount * 38))
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text .. ": ВЫКЛ"
    btn.TextColor3 = Color3.fromRGB(255, 100, 100)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 14
    btn.Parent = ContentFrame
    
    btn.MouseButton1Click:Connect(function()
        Settings[configKey] = not Settings[configKey]
        if Settings[configKey] then
            btn.BackgroundColor3 = Color3.fromRGB(50, 90, 50)
            btn.Text = text .. ": ВКЛ"
            btn.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            btn.Text = text .. ": ВЫКЛ"
            btn.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        if callback then callback(Settings[configKey]) end
    end)
    buttonCount = buttonCount + 1
end

